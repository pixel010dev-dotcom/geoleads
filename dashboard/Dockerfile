FROM node:20-slim

WORKDIR /app

COPY package*.json ./
RUN npm ci --legacy-peer-deps --omit=dev && npm cache clean --force

COPY . .

ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_ENV=production
ENV HOSTNAME=0.0.0.0
ENV PORT=3000

ARG NEXT_PUBLIC_SUPABASE_URL=https://placeholder.supabase.co
ARG NEXT_PUBLIC_SUPABASE_ANON_KEY=placeholder
ARG GEMINI_API_KEY=placeholder
ARG GEMINI_MODEL=gemini-1.5-flash
ARG NEXT_PUBLIC_APP_URL=https://geoleads-production.up.railway.app
ARG SUPABASE_SERVICE_ROLE_KEY=placeholder
ARG GOOGLE_CSE_API_KEY=placeholder
ARG GOOGLE_CSE_ID=placeholder
ARG CF_WORKER_URL=https://placeholder.workers.dev

ENV NEXT_PUBLIC_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL
ENV NEXT_PUBLIC_SUPABASE_ANON_KEY=$NEXT_PUBLIC_SUPABASE_ANON_KEY
ENV GEMINI_API_KEY=$GEMINI_API_KEY
ENV GEMINI_MODEL=$GEMINI_MODEL
ENV NEXT_PUBLIC_APP_URL=$NEXT_PUBLIC_APP_URL
ENV SUPABASE_SERVICE_ROLE_KEY=$SUPABASE_SERVICE_ROLE_KEY
ENV GOOGLE_CSE_API_KEY=$GOOGLE_CSE_API_KEY
ENV GOOGLE_CSE_ID=$GOOGLE_CSE_ID
ENV CF_WORKER_URL=$CF_WORKER_URL

RUN npm run build

EXPOSE 3000

CMD ["npm", "run", "start"]
